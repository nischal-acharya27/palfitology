  "tech_stack": {
    "runtime": {
      "python": ">=3.10 (cluster: 3.11)",
      "shell": "bash (SGE submit scripts)",
      "package_manager": "pip + conda (cluster ships heavy deps as conda binaries)"
    },
    "deps_runtime": {
      "numpy": ">=1.24",
      "scipy": ">=1.10",
      "pandas": ">=2.0",
      "matplotlib": ">=3.7",
      "astropy": ">=5.3",
