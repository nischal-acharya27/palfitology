    {"from": "package",    "to": "psf",        "kind": "re-export"}
  ],

  "data_flows": [
    {
      "id": "fit-pa-flow",
      "label": "palfitology fit-pa",
      "edges": [
        {"from": "catalog.csv",                "to": "catalog",  "via": "load_catalog",                "carries": "DataFrame[id, A_WORLD, B_WORLD, pa_jplus, R_EFF?]"},
        {"from": "catalog",                    "to": "pipeline", "via": "fit_catalog",                 "carries": "DataFrame"},
        {"from": "images/<id>/*.fits",         "to": "images",   "via": "locate_band_fits",            "carries": "Path"},
        {"from": "images",                     "to": "psf",      "via": "locate_band_psf + open",      "carries": "(image, psf_path, r_eff_pixels)"},
        {"from": "psf",                        "to": "fit",      "via": "preprocess_for_fit",          "carries": "PSFInfo(image_for_fit, mode, psf_fwhm_pixels)"},
        {"from": "fit",                        "to": "selection","via": "_fit_once",                   "carries": "iso_table"},
        {"from": "selection",                  "to": "fit",      "via": "select_isophote",             "carries": "(row_idx, weak)"},
        {"from": "fit",                        "to": "pipeline", "via": "fit_pa_with_fallbacks",       "carries": "(FitCandidate|None, n_tried)"},
        {"from": "pipeline",                   "to": "plots",    "via": "make_band_plot",              "carries": "FitCandidate + raw image"},
        {"from": "pipeline",                   "to": "fitted_pa_images/<id>/<band>_PA_fit.png", "via": "savefig"},
        {"from": "pipeline",                   "to": "fitted_pa_images/<id>/<id>_summary.png",  "via": "make_summary_mosaic"},
        {"from": "pipeline",                   "to": "fitted_pa_images/PA_results.csv",         "via": "DataFrame.to_csv"}
      ]
    },
    {
      "id": "reconcile-flow",
      "label": "palfitology reconcile --plot",
      "edges": [
        {"from": "fitted_pa_images/<id>/PA_fits.csv", "to": "reconcile", "via": "_gather_per_object_fits", "carries": "long DataFrame"},
        {"from": "catalog.csv",                       "to": "reconcile", "via": "load_catalog",            "carries": "DataFrame[id, pa_jplus]"},
        {"from": "reconcile",                         "to": "fitted_pa_images/PA_reconciliation.csv",      "via": "to_csv"},
        {"from": "reconcile",                         "to": "fitted_pa_images/PA_reconciliation_<band>.png", "via": "plot_reconciliation"}
      ]
    },
    {
      "id": "cluster-array-flow",
      "label": "SGE 8-task array",
      "edges": [
        {"from": "catalog.csv",                 "to": "prepare_chunks.sh",        "via": "pandas split",        "carries": "cat_part_01..08.csv"},
        {"from": "cat_part_NN.csv",             "to": "run_palfitology_array.sh", "via": "qsub -t 1-8 -tc 8",   "carries": "per-task fit-pa invocation"},
        {"from": "fitted_pa_images_part_NN/",   "to": "merge_and_reconcile.sh",   "via": "qsub -hold_jid",      "carries": "merged fitted_pa_images/"}
      ]
    }
  ],

  "csv_schemas": {
    "PA_results.csv": {
      "rows_per": "(object, band)",
      "row_count_example": 242736,
      "columns": [
        {"name": "id",                 "type": "str",   "desc": "Object id (TILE-NUMBER)"},
        {"name": "band",               "type": "str",   "desc": "One of the 12 J-PLUS bands"},
        {"name": "fits_path",          "type": "str",   "desc": "Absolute path to cutout"},
        {"name": "est_pa",             "type": "float", "desc": "Fitted PA in degrees (CCW from +x, image frame)"},
        {"name": "est_sma",            "type": "float", "desc": "Semi-major axis, pixels"},
        {"name": "est_ell",            "type": "float", "desc": "Ellipticity 1 - b/a"},
        {"name": "x0",                 "type": "float", "desc": "Fitted center x"},
        {"name": "y0",                 "type": "float", "desc": "Fitted center y"},
        {"name": "pa_err",             "type": "float", "desc": "Uncertainty on PA, degrees"},
        {"name": "selection_score",    "type": "float", "desc": "pa_err / sma; lower is better"},
        {"name": "fit_config",         "type": "str",   "desc": "Which fallback config produced the winning fit"},
        {"name": "smoothing_sigma",    "type": "float", "desc": "Gaussian sigma applied before fitting"},
        {"name": "used_weak_fallback", "type": "int",   "desc": "1 if no isophote cleared the SMA floor"},
        {"name": "n_configs_tried",    "type": "int",   "desc": "Total fallback ladder steps attempted"},
        {"name": "is_imputed",         "type": "int",   "desc": "1 if all fits failed and priors were used"},
        {"name": "status",             "type": "str",   "desc": "ok | weak | imputed | missing"},
        {"name": "psf_mode",           "type": "str",   "desc": "raw | deconv | deconv->raw_fallback | missing_psf | off"},
        {"name": "psf_fwhm_pixels",    "type": "float", "desc": "Measured PSF FWHM, pixels"}
      ]
    },
    "PA_reconciliation.csv": {
      "rows_per": "object",
      "row_count_example": 6522,
      "columns": [
        {"name": "id",                "type": "str"},
        {"name": "pa_jplus",          "type": "float", "desc": "Catalog PA, sky frame (east of north)"},
        {"name": "pa_jplus_norm",     "type": "float", "desc": "(90 - pa_jplus) mod 180 -- photutils frame"},
        {"name": "pa_median_ok",      "type": "float", "desc": "Per-object median of OK bands"},
        {"name": "pa_diff_median",    "type": "float", "desc": "Circular diff median vs catalog, [0, 90]"},
        {"name": "n_bands_ok",        "type": "int"},
        {"name": "n_bands_weak",      "type": "int"},
        {"name": "n_bands_missing",   "type": "int"},
        {"name": "pa_<band>",         "type": "float", "desc": "Per-band fitted PA wrapped to [0, 180)"},
        {"name": "pa_diff_<band>",    "type": "float", "desc": "Per-band circular diff vs catalog"}
      ]
    }
  },

  "filesystem": {
    "input_layout": {
      "images/<id>/fits_images_<ra>_<dec>/<band>_cutout.fits": "12 per object",
      "images/<id>/psfs_<ra>_<dec>/psf_<ra>_<dec>_<band>.fits": "12 per object",
      "<catalog>.csv": "ADQL output or pre-processed (id, A_WORLD, B_WORLD, pa_jplus, R_EFF in pixels)"
    },
    "output_layout": {
      "fitted_pa_images/<id>/<band>_PA_fit.png": "diagnostic, 12 per object",
      "fitted_pa_images/<id>/<id>_summary.png":  "3x4 mosaic per object",
      "fitted_pa_images/<id>/PA_fits.csv":       "12 rows per object",
      "fitted_pa_images/all_summaries/<id>_summary.png": "central mosaic copies",
      "fitted_pa_images/PA_results.csv":         "master table",
      "fitted_pa_images/PA_reconciliation.csv":  "wide cross-match",
      "fitted_pa_images/PA_reconciliation_<band>.png": "scatter plots"
    }
  },

  "constants": {
    "ALL_BANDS": ["uJAVA", "J0378", "J0395", "J0410", "J0430", "gSDSS", "J0515", "rSDSS", "J0660", "iSDSS", "J0861", "zSDSS"],
    "DEFAULT_PSF_GATE": 0.2,
    "default_sma_floor_px": 3.0,
    "default_sma_floor_frac": 0.05,
    "default_keep_best_of": 8,
    "n_mc_seeds": 50,
    "mc_seed": 42,
    "smoothing_ladder_sigma": [0.0, 2.0],
    "wiener_regularization_floor": 1e-6
  },

  "conventions": [
    {"id": "pa-units",       "rule": "photutils returns PA in degrees, CCW from +x (image frame). Do NOT apply rad2deg."},
    {"id": "pa-wrap",        "rule": "All PAs wrapped to [0, 180) before comparison -- PA is direction-only."},
    {"id": "pa-diff",        "rule": "Circular diff in [0, 90]: min(|a-b| mod 180, 180 - |a-b| mod 180)."},
    {"id": "pa-catalog-map", "rule": "transform_pa_jplus(d) = (90 - d) mod 180 brings sky-frame catalog PA into photutils' image frame."},
    {"id": "parallelism",    "rule": "Per (object, band) tasks via ProcessPoolExecutor. BLAS pinned to 1 thread/worker BEFORE numpy imports."},
    {"id": "psf-gate",       "rule": "psf-mode=auto deconvolves when psf_fwhm_pixels / r_eff_pixels >= gate (default 0.2)."},
    {"id": "psf-fallback",   "rule": "If deconvolved fit imputes, retry on raw cutout and label psf_mode='deconv->raw_fallback'."},
    {"id": "psf-hdu",        "rule": "PSF loader walks HDU list for first 2D image. J-PLUS PSFEx puts data in HDU[1], not HDU[0]."}
  ],

  "constraints": [
    {"category": "numerical", "rule": "Wiener K must be >= regularization_floor (1e-6). Smaller values cause noise amplification on shallow narrowband cutouts."},
    {"category": "numerical", "rule": "SMA floor = max(3 px, 0.05 * image_half_width). Below this, photutils returns degenerate sub-pixel isophotes with artificially low pa_err."},
    {"category": "data",      "rule": "R_EFF column must be in PIXELS (not arcsec) when psf-mode is auto or on. Missing column -> warning + fall back to 'raw' everywhere."},
    {"category": "perf",      "rule": "12N tasks for N objects. ProcessPoolExecutor with workers = NSLOTS; do NOT exceed cores per node or BLAS contention dominates."},
    {"category": "perf",      "rule": "Per-object mosaic is finalized when its last band returns -- mosaics appear throughout the run, not only at the end."},
    {"category": "cluster",   "rule": "LD_PRELOAD=$CONDA_PREFIX/lib/libgomp.so.1 required on hpc-login (static-TLS dlopen workaround)."},
    {"category": "cluster",   "rule": "`set -u` must come AFTER `conda activate` -- mpivars.deactivate.sh references unbound variables."},
    {"category": "cluster",   "rule": "qsub -wd or -cwd: SGE inherits the submission directory. Held reconcile job must share cwd with the array tasks."},
    {"category": "cluster",   "rule": "Cluster ships old GCC (4.8.4). Run pip install -e . inside the 'palfitology' conda env so numpy/scipy/astropy come from prebuilt conda binaries, not source builds."},
    {"category": "git",       "rule": "Sandbox cannot commit/push for the user; always instruct user to commit and push on their laptop."}
  ],

  "adrs": [
    {
      "id": "ADR-001",
      "title": "Refactor V7 monolith into installable package",
      "status": "accepted",
      "context": "AutomatedPositionAngleV5/V6/V7.py grew to ~1600 lines. Hard to test, share, or evolve.",
      "decision": "Split into src/palfitology/{catalog,images,selection,fit,plots,pipeline,cli,reconcile}.py with explicit imports. Keep V*.py scripts as read-only reference."
    },
    {
      "id": "ADR-002",
      "title": "Wiener deconvolution with FWHM gate instead of full convolved modelling",
      "status": "accepted",
      "context": "GALFIT downstream does proper convolved-model fitting. Palfitology only needs to give it good PA priors. Full convolved fitting in palfitology would reimplement GALFIT.",
      "decision": "Conservative Wiener deconvolution gated on psf_fwhm/r_eff ratio. When PSF is small relative to galaxy, skip deconv to avoid noise amplification."
    },
    {
      "id": "ADR-003",
      "title": "ProcessPoolExecutor at (object, band) granularity, not (object)",
      "status": "accepted",
      "context": "Catalogs may have only a few hundred objects, but a 40-core node has 40 cores.",
      "decision": "12N tasks for N objects. Even small catalogs saturate big nodes. Trade-off: 12x more IPC overhead, but bands within an object have no shared compute."
    },
    {
      "id": "ADR-004",
      "title": "BLAS thread pinning set in cli.py BEFORE numpy import",
      "status": "accepted",
      "context": "Workers inherit env, but the parent also imports numpy and would otherwise default to 40 BLAS threads.",
      "decision": "os.environ.setdefault for OMP_NUM_THREADS etc. at the top of cli.py, AND repeated in pipeline._worker_init for each child."
    },
    {
      "id": "ADR-005",
      "title": "transform_pa_jplus = (90 - pa) mod 180 instead of WCS lookup",
      "status": "tentative",
      "context": "photutils returns image-frame CCW-from-+x; J-PLUS catalog pa_jplus is sky-frame east-of-north. Empirically the (90 - pa) mod 180 transform collapses scatter onto y=x for the deep broadbands.",
      "decision": "Use this empirical mapping for now. V0.2 cluster run shows ~70% of rSDSS rows agree with this; 30% don't. May upgrade to per-cutout CD-matrix conversion in a follow-up (see open_questions.pa_split)."
    },
    {
      "id": "ADR-006",
      "title": "psf_mode 'deconv->raw_fallback' rather than dropping the row",
      "status": "accepted",
      "context": "On low-S/N cutouts, deconvolution can amplify noise enough that fit_pa_with_fallbacks imputes. Dropping those rows loses information.",
      "decision": "If deconvolved fit imputes, retry on raw cutout. Track outcome in psf_mode column so downstream filtering is possible."
    },
    {
      "id": "ADR-007",
      "title": "Selection score = pa_err / sma instead of pa_err alone",
      "status": "accepted",
      "context": "V4/V5 picked the row with the smallest pa_err. For face-on galaxies this collapsed to sub-pixel isophotes with artificially low pa_err.",
      "decision": "Add SMA floor + use ratio score. Outermost-surviving fallback for face-on cases (weak=True)."
    }
  ],

