    },
    "build": {
      "backend": "setuptools >= 68",
      "layout": "src-layout (src/palfitology/)",
      "wheel": "py3-none-any (pure Python)"
    },
    "scheduler": "SGE (CEFCA hpc-login), 40 cores/node",
    "version_control": {
      "remote": "https://github.com/nischal-acharya27/palfitology",
      "current_branch": "feature/v0.2-psf",
      "main_branch": "main"
    }
  },

  "entry_points": {
    "console_script": {
      "name": "palfitology",
      "module": "palfitology.cli:main",
      "subcommands": ["fit-pa", "reconcile", "download", "consensus", "galfit"]
    },
    "python_api": [
      {"symbol": "palfitology.fit_catalog",          "module": "palfitology.pipeline",  "kind": "function"},
      {"symbol": "palfitology.fit_pa_with_fallbacks","module": "palfitology.fit",       "kind": "function"},
      {"symbol": "palfitology.preprocess_for_fit",   "module": "palfitology.psf",       "kind": "function"},
      {"symbol": "palfitology.FitCandidate",         "module": "palfitology.fit",       "kind": "dataclass"},
      {"symbol": "palfitology.PSFInfo",              "module": "palfitology.psf",       "kind": "dataclass"},
      {"symbol": "palfitology.ALL_BANDS",            "module": "palfitology",           "kind": "constant"}
    ],
    "cli_invocations": [
      "palfitology fit-pa --catalog 1638518.csv --images-root images --workers 40 --psf-mode auto --psf-gate 0.2",
      "palfitology reconcile --plot --catalog 1638518.csv",
      "palfitology --version"
    ]
  },

